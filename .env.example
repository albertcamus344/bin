# ── Required ──────────────────────────────────────────────────────────────────

# Telegram bot token — get one from @BotFather on Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Google AI Studio API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────

# Gemini model to use. Free-tier options:
#   gemini-1.5-flash  (fast, generous free limits — recommended)
#   gemini-1.5-pro    (smarter, lower free limits)
#   gemini-2.0-flash  (newer, check availability on your account)
GEMINI_MODEL=gemini-1.5-flash

# Restrict the bot to specific Telegram user IDs (comma-separated).
# Leave blank to allow anyone who messages the bot.
# Find your ID by messaging @userinfobot on Telegram.
ALLOWED_USER_IDS=

# Override the default system prompt to change the assistant's personality/role.
# SYSTEM_PROMPT=You are a concise assistant who always replies in bullet points.
